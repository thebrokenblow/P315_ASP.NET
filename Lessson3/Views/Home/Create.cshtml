@using Lesson3.Models

@model Product

@{
    ViewData["Title"] = "Добавление продукта";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h3>Добавление нового продукта</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        
                        <div class="form-group mb-3">
                            <input asp-for="Name" class="form-control" placeholder="Введите название продукта" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <select asp-for="Category" class="form-select">
                                <option value="">Выберите категорию</option>
                                <option value="Электроника">Электроника</option>
                                <option value="Аксессуары">Аксессуары</option>
                                <option value="Книги">Книги</option>
                                <option value="Одежда">Одежда</option>
                                <option value="Дом и сад">Дом и сад</option>
                            </select>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label asp-for="Price" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Price" class="form-control" placeholder="0.00" />
                            </div>
                        </div>
                        
                        <div class="form-group mb-3">
                            <input asp-for="Quantity" class="form-control" placeholder="Введите количество" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Введите описание продукта"></textarea>
                        </div>
                        
                        <div class="form-group">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-plus-circle"></i> Добавить продукт
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5>Информация</h5>
                </div>
                <div class="card-body">
                    <p>Заполните все поля формы для добавления нового продукта в каталог.</p>
                    <hr />
                    <h6>Правила заполнения:</h6>
                    <ul>
                        <li>Название - обязательно для заполнения</li>
                        <li>Цена должна быть больше 0</li>
                        <li>Количество не может быть отрицательным</li>
                        <li>Категория выбирается из списка</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>